# ============================================
# AUREON by Rhematek Solutions
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# DJANGO CORE SETTINGS
# ============================================
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-use-strong-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,aureon.rhematek-solutions.com,*.aureon.rhematek-solutions.com
DJANGO_SETTINGS_MODULE=config.settings_aureon
ENVIRONMENT=production

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_NAME=aureon_db
DB_USER=aureon_user
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_IN_PRODUCTION
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_IN_PRODUCTION
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# ============================================
# STRIPE PAYMENT INTEGRATION
# ============================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
DJSTRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ============================================
# EMAIL CONFIGURATION
# ============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@rhematek-solutions.com
EMAIL_HOST_PASSWORD=your-app-specific-password-here
DEFAULT_FROM_EMAIL=noreply@rhematek-solutions.com
SERVER_EMAIL=alerts@rhematek-solutions.com

# ============================================
# COMPANY & BRANDING
# ============================================
COMPANY_NAME=Rhematek Solutions
PROJECT_NAME=Aureon
CEO_NAME=Stéphane Arthur Victor
CEO_EMAIL=stephane@rhematek-solutions.com
ADMIN_EMAIL=alerts@rhematek-solutions.com
SITE_NAME=Aureon - Automated Financial Management
SITE_URL=https://aureon.rhematek-solutions.com

# ============================================
# AWS S3 STORAGE (Optional)
# ============================================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=aureon-media-storage
AWS_S3_REGION_NAME=us-east-1

# ============================================
# SECURITY SETTINGS
# ============================================
# Set to True in production with HTTPS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://www.googletagmanager.com
CSP_STYLE_SRC='self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net
CSP_FONT_SRC='self' https://fonts.gstatic.com data: https://cdn.jsdelivr.net
CSP_IMG_SRC='self' data: https: blob:
CSP_CONNECT_SRC='self' https://api.stripe.com https://www.google-analytics.com

# ============================================
# SOCIAL AUTHENTICATION (Optional)
# ============================================
# Google OAuth: https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ============================================
# ERROR TRACKING & MONITORING
# ============================================
# Sentry DSN: https://sentry.io/
SENTRY_DSN=

# Grafana Admin Password
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD

# Flower (Celery Monitoring) Credentials
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_THIS_FLOWER_PASSWORD

# ============================================
# CELERY TASK QUEUE
# ============================================
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ============================================
# API RATE LIMITING
# ============================================
RATELIMIT_ENABLE=True
RATELIMIT_USE_CACHE=default

# ============================================
# DOCUSIGN E-SIGNATURE (Optional)
# ============================================
# DocuSign Developer Account: https://developers.docusign.com/
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_ANALYTICS=True
ENABLE_INTEGRATIONS=True
ENABLE_WEBHOOKS=True
ENABLE_NOTIFICATIONS=True

# ============================================
# COMPLIANCE & DATA RETENTION
# ============================================
DATA_RETENTION_DAYS=2555  # 7 years for financial records
GDPR_ENABLED=True
AUDIT_LOG_ENABLED=True

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=https://aureon.rhematek-solutions.com,http://localhost:3000,http://127.0.0.1:3000

# ============================================
# ANALYTICS & TRACKING (Optional)
# ============================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
FACEBOOK_PIXEL_ID=

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_RETENTION_DAYS=30

# ============================================
# NOTES
# ============================================
# 1. Generate a strong SECRET_KEY using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 2. Use strong passwords for all password fields
# 3. Enable HTTPS in production (set SECURE_* settings to True)
# 4. Configure Stripe webhooks at: https://dashboard.stripe.com/webhooks
# 5. Set up proper email service (Gmail, AWS SES, SendGrid, etc.)
# 6. Configure monitoring and error tracking
# 7. Review security settings before going live
# 8. Test all integrations in development/staging first
# 9. Keep this file secure - never commit .env to git!
# 10. For production, use environment variables or secrets management

# ============================================
# END OF CONFIGURATION
# ============================================
