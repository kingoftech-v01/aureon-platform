{% load static %}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <!-- Homepage -->
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:home' %}</loc>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>

    <!-- Static Pages -->
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:about' %}</loc>
        <changefreq>monthly</changefreq>
        <priority>0.8</priority>
    </url>
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:team' %}</loc>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:services' %}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:pricing' %}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:contact' %}</loc>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>

    <!-- Blog Posts -->
    {% if show_blog %}
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:blog' %}</loc>
        <changefreq>daily</changefreq>
        <priority>0.8</priority>
    </url>
    {% endif %}

    <!-- Products -->
    {% if show_store %}
    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'website:products' %}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>
    {% endif %}

    <!-- Add dynamic URLs here via views if needed -->
</urlset>
